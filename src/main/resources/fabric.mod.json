{
  "schemaVersion": 1,
  "id": "${modId}",
  "version": "${version}",
  "name": "Custom Paintings",
  "description": "Add your own custom paintings to Minecraft.",
  "authors": [
    "Roundaround"
  ],
  "contact": {
    "homepage": "https://modrinth.com/mod/custom-paintings-mod",
    "sources": "https://github.com/Roundaround/mc-fabric-custom-paintings",
    "issues": "https://github.com/Roundaround/mc-fabric-custom-paintings/issues"
  },
  "license": "MIT",
  "custom": {
    "loom:injected_interfaces": {
      "net/minecraft/client/renderer/entity/state/PaintingRenderState": [
        "me/roundaround/custompaintings/client/render/entity/state/PaintingRenderStateExtensions"
      ],
      "net/minecraft/world/entity/decoration/painting/Painting": [
        "me/roundaround/custompaintings/entity/decoration/painting/PaintingExtensions"
      ],
      "net/minecraft/server/level/ServerLevel": [
        "me/roundaround/custompaintings/server/world/ServerLevelExtensions"
      ]
    }
  }
}
